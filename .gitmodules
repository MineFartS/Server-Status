[submodule "lib/msys2"]
	path = lib/msys2
	url = https://github.com/MineFartS/MSYS2
    ignore = all

[submodule "lib/json"]
	path = lib/json
	url = https://github.com/nlohmann/json
	branch = develop
    ignore = all

[submodule "lib/pybind11"]
	path = lib/pybind11
	url = https://github.com/pybind/pybind11
	branch = stable
    ignore = all

[submodule "lib/python314"]
	path = lib/python314
	url = https://github.com/MineFartS/python-embed
    ignore = all
